{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "vue-tsc --noEmit && bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "lint": "eslint --fix .",
    "format": "prettier --write .",
    "api:types": "bunx openapi-typescript \"${OPENAPI_URL:-http://localhost:8000/openapi.json}\" -o src/shared/api/generated/openapi.ts"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.5.4",
    "openapi-fetch": "^0.17.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.28",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@primevue/auto-import-resolver": "^4.5.4",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.5.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-sort-json": "^4.2.0",
    "sass": "^1.97.3",
    "typescript": "~5.9.3",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.4",
    "openapi-typescript": "^7.13.0"
  }
}